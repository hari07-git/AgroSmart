## AgroSmart Environment Variables

# Flask
SECRET_KEY=change-me

# OTP Email Verification (members)
REQUIRE_EMAIL_OTP=1
OTP_DEBUG_SHOW=0
BOOTSTRAP_ADMIN=1
ADMIN_EMAIL=admin@agrosmart.com
ADMIN_PASSWORD=admin@1234
ADMIN_NAME=AgroSmart Admin

# Email delivery
# console = print/capture OTP in server logs (dev)
# smtp    = send via SMTP (often blocked on PaaS)
# resend  = send via HTTPS email API (recommended for Render)
EMAIL_DELIVERY=resend

# SMTP settings (example values; replace with your provider details)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_agrosmart_email@gmail.com
SMTP_PASS=your_app_password_or_smtp_password
SMTP_FROM=AgroSmart <your_agrosmart_email@gmail.com>
SMTP_TLS=1
SMTP_SSL=0

# Resend settings (recommended on Render)
RESEND_API_KEY=your_resend_api_key
# Note: Resend requires a verified sender/domain for custom From addresses.
# For demo you can use your verified sender in Resend.
RESEND_FROM=AgroSmart <onboarding@resend.dev>

# Weather (optional)
OPENWEATHER_API_KEY=your_key_here
